rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks both UID AND Email for absolute certainty
    function isAdmin() {
      return isSignedIn() && 
        (request.auth.uid == '2gQdFftRQzR2O77UQhAAJdtneCw2' || 
         request.auth.token.email == 'support@seotube.io');
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      // Protect sensitive fields from client-side updates
      allow update: if isSignedIn() && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).changedKeys().hasAny(['plan', 'credits']);
    }

    // --- Blog Posts Collection ---
    match /posts/{postId} {
      // Publicly readable for SEO
      allow read: if true;

      // Split 'write' into specific permissions for better debugging
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}